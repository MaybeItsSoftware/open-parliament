# Release lanes for Open Parliament (Flutter).
#
#   bundle exec fastlane ios beta       # build IPA → TestFlight (called by deploy.yml on tag)
#   bundle exec fastlane ios release    # submit latest TestFlight build for App Store review
#   bundle exec fastlane android beta   # build AAB → Play internal + closed (alpha) testing
#   bundle exec fastlane android promote # promote internal → production
#
# Auth is via an App Store Connect API key (iOS) and a Play service account
# (Android), both supplied through env vars in CI. iOS signing comes from
# `match`; Android signing from gradle's key.properties (written by CI).

ROOT   = File.expand_path("..", __dir__)
APP_ID = "uk.co.maybeitssoftware.openparliament"
TEAM_ID = ENV["TEAM_ID"] || "6NQNU5YSC2"

# BUILD_NUMBER must be set by CI (deploy.yml passes github.run_number).
# Both stores require a strictly increasing integer across every submission, so
# this must never fall back silently — an accidental local submission with a
# high formula-derived number would block all future CI uploads with lower
# run numbers. Run locally only with an explicit: BUILD_NUMBER=<n> bundle exec fastlane …
BUILD_NUMBER = ENV.fetch("BUILD_NUMBER") { raise "BUILD_NUMBER env var is required. Set it to a value higher than the last store submission." }
BUILD_ARG = " --build-number=#{BUILD_NUMBER}"

platform :ios do
  desc "Build a signed release IPA and upload it to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id:                  ENV["ASC_KEY_ID"],
      issuer_id:               ENV["ASC_ISSUER_ID"],
      key_content:             ENV["ASC_KEY_CONTENT"],
      is_key_content_base64:   true,
    )

    match(
      type:           "appstore",
      app_identifier: APP_ID,
      api_key:        api_key,
      readonly:       is_ci,
    )

    update_code_signing_settings(
      path:                 File.join(ROOT, "ios", "Runner.xcodeproj"),
      use_automatic_signing: false,
      team_id:              TEAM_ID,
      code_sign_identity:   "Apple Distribution",
      profile_name:         "match AppStore #{APP_ID}",
      bundle_identifier:    APP_ID,
      targets:              ["Runner"],
    )

    sh("cd #{ROOT} && flutter build ipa --release#{BUILD_ARG} --export-options-plist=ios/ExportOptions.plist")

    upload_to_testflight(
      api_key:                          api_key,
      ipa:                              Dir.glob(File.join(ROOT, "build", "ios", "ipa", "*.ipa")).first,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit a processed TestFlight build for App Store review"
  lane :release do
    # Strip leading 'v' so App Store Connect gets a plain semver (e.g. "0.2.0").
    version = (ENV["VERSION"] || "").sub(/\Av/, "")

    api_key = app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    upload_to_app_store(
      api_key:             api_key,
      app_identifier:      APP_ID,
      app_version:         version,
      # The binary is already on TestFlight — skip re-uploading the IPA.
      skip_binary_upload:  true,
      # Metadata lives in fastlane/metadata/ — upload it with the submission.
      # Set skip_metadata: true if you manage metadata manually in App Store Connect.
      skip_metadata:       false,
      metadata_path:       File.join(__dir__, "metadata"),
      # Screenshots live in fastlane/screenshots/. Set to true to skip.
      skip_screenshots:    false,
      screenshots_path:    File.join(__dir__, "screenshots"),
      submit_for_review:   true,
      # Release manually after Apple approves, so you control the rollout moment.
      automatic_release:   false,
      force:               true, # skip the HTML diff report
      # Mark as not using encryption (update if the app uses crypto APIs).
      export_compliance_uses_encryption: false,
    )
  end
end

platform :android do
  desc "Build a signed release AAB and upload it to Play internal + closed (alpha) testing"
  lane :beta do
    sh("cd #{ROOT} && flutter build appbundle --release#{BUILD_ARG}")

    # Uploads to "internal" and, in the same edit/transaction, promotes that
    # same release to "alpha" (Play Console labels this "Closed testing -
    # Alpha"). Doing both in one upload_to_play_store call matters: two
    # separate calls each open their own Play API edit, and a second call
    # trying to read back the first call's just-committed internal release
    # can race it and fail with "Track 'internal' doesn't have any releases".
    #
    # track_promote_release_status is "draft" (not "completed") because this
    # app has never had a live release on a non-internal track — until a
    # human completes the first-ever rollout on the alpha track from Play
    # Console (pick countries, confirm policies, "Start rollout"), the API
    # rejects "completed" there with "Only releases with status draft may be
    # created on draft app." Once that one-time manual rollout is done, this
    # can switch to "completed".
    upload_to_play_store(
      package_name:                  APP_ID,
      track:                         "internal",
      track_promote_to:              "alpha",
      track_promote_release_status:  "draft",
      aab:                           File.join(ROOT, "build", "app", "outputs", "bundle", "release", "app-release.aab"),
      json_key_data:                 ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      skip_upload_apk:               true,
      # Metadata and screenshots are managed via the promote lane; keep beta
      # uploads fast by skipping them here.
      skip_upload_metadata:          true,
      skip_upload_images:            true,
      skip_upload_screenshots:       true,
    )
  end

  desc "Promote the current internal-track build to production"
  lane :promote do
    upload_to_play_store(
      package_name:          APP_ID,
      track:                 "internal",
      track_promote_to:      "production",
      json_key_data:         ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      skip_upload_apk:       true,
      skip_upload_aab:       true,
      # Upload store listing metadata and screenshots alongside the promotion.
      # Set to true if you manage these in Play Console directly.
      skip_upload_metadata:  false,
      skip_upload_images:    false,
      skip_upload_screenshots: false,
      metadata_path:         File.join(__dir__, "metadata", "android"),
      # Optional staged rollout — start at 10 % and ramp via Play Console.
      # rollout: "0.1",
    )
  end
end
